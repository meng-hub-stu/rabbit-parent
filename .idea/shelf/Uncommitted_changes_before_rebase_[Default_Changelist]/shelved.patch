<+>package com.bfxy.base.rabbit.producer.broker;\r\n\r\nimport com.bfxy.base.rabbit.api.Message;\r\nimport com.bfxy.base.rabbit.api.MessageProducer;\r\nimport com.bfxy.base.rabbit.api.MessageType;\r\nimport com.bfxy.base.rabbit.api.SendCallback;\r\nimport com.bfxy.base.rabbit.api.exception.MessageRunTimeException;\r\nimport com.google.common.base.Preconditions;\r\nimport org.springframework.amqp.rabbit.core.RabbitTemplate;\r\nimport org.springframework.beans.factory.annotation.Autowired;\r\nimport org.springframework.stereotype.Component;\r\n\r\nimport java.util.List;\r\n\r\n/**\r\n * 发送消息的实现类\r\n * @Author Mengdexin\r\n * @date 2022 -04 -18 -22:18\r\n */\r\n@Component\r\npublic class ProducerClient implements MessageProducer {\r\n\r\n    @Autowired\r\n    private RabbitBroker rabbitBroker;\r\n\r\n    @Override\r\n    public void send(Message message) throws MessageRunTimeException {\r\n        Preconditions.checkNotNull(message);\r\n        String messageType = message.getMessageType();\r\n        //发送三种类型的消息\r\n        switch (messageType) {\r\n            case MessageType.RAPID:\r\n                rabbitBroker.rapidSend(message);\r\n                break;\r\n            case MessageType.CONFIRM:\r\n                break;\r\n            case MessageType.RELIANT:\r\n                break;\r\n            default:\r\n                break;\r\n        }\r\n\r\n    }\r\n\r\n    @Override\r\n    public void send(List<Message> messages) throws MessageRunTimeException {\r\n\r\n    }\r\n\r\n    @Override\r\n    public void send(Message message, SendCallback sendCallback) throws MessageRunTimeException {\r\n\r\n    }\r\n\r\n}\r\n
